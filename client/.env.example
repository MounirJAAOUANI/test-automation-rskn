# ─────────────────────────────────────────────────────────────────────────────
# client/.env.local  —  Copie ce fichier en .env.local et remplis chaque valeur
# Préfixe VITE_ obligatoire pour que Vite expose la variable au navigateur
# ⚠️  Ne jamais committer ce fichier sur GitHub (il est dans .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# production = vrais appels API + mot de passe requis
# development = données simulées + aucun mot de passe requis
VITE_MODE_ENV=development

# Le vrai mot de passe attendu (comparé à VITE_FILLED_PASSWORD)
VITE_TRUE_PASSWORD=launch2026

# Si égal à TRUE_PASSWORD → popup de mot de passe bypasse automatiquement
# Laisser vide en développement
VITE_FILLED_PASSWORD=launch2026

# true  → afficher les boutons "Exécuter" sur chaque étape
# false → afficher seulement le gros bouton "Lancer la pipeline complète"
VITE_SHOW_STEPS=true

# true → afficher le détail complet des erreurs dans les encarts
# false → afficher seulement le message d'erreur simplifié
VITE_MOT_DEBUG=false
