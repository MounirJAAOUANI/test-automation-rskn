# ─────────────────────────────────────────────────────────────────────────────
# server/.env  —  Copie ce fichier en .env et remplis chaque valeur
# ⚠️  Ne jamais committer ce fichier sur GitHub (il est dans .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── Serveur ──────────────────────────────────────────────────────────────────
PORT=4000

# production = vrais appels API / development = données simulées
MODE_ENV=development

# true = erreurs détaillées dans les réponses SSE / false = message simple
MOT_DEBUG=false

# URL du frontend (pour autorisation CORS)
FRONTEND_URL=http://localhost:5173

# ── Claude API (Anthropic) ────────────────────────────────────────────────────
# Obtenir sur : https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-api03-REMPLACE-PAR-TA-VRAIE-CLE

# ── OpenAI API (logo generation) ─────────────────────────────────────────────
# Obtenir sur : https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-REMPLACE-PAR-TA-VRAIE-CLE

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Obtenir sur : console.firebase.google.com → Paramètres → Comptes de service
# IMPORTANT : coller le JSON sur UNE SEULE LIGNE (minifié)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"TON-PROJECT-ID","private_key_id":"XXXX","private_key":"-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-XXXX@TON-PROJECT-ID.iam.gserviceaccount.com","client_id":"XXXX","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ── Google Play Console API ───────────────────────────────────────────────────
# Obtenir sur : play.google.com/console → Configuration → Accès API → Compte de service
# IMPORTANT : coller le JSON sur UNE SEULE LIGNE (minifié)
GOOGLE_PLAY_SERVICE_ACCOUNT={"type":"service_account","project_id":"pc-api-XXXX","private_key_id":"XXXX","private_key":"-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n","client_email":"pc-api-XXXX@developer.gserviceaccount.com","client_id":"XXXX","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Ton ID développeur Play Console (visible dans l'URL de la console)
GOOGLE_PLAY_DEVELOPER_ID=XXXXXXXXXXXX

# ── GitHub ────────────────────────────────────────────────────────────────────
# Obtenir sur : github.com → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=ghp_REMPLACE-PAR-TON-VRAI-TOKEN
GITHUB_OWNER=ton-username-github
GITHUB_REPO=app-factory-flutter
